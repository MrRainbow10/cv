{
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/ponytail/hooks/ponytail-statusline.sh\""
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"$CLAUDE_PROJECT_DIR/.claude/ponytail/hooks/ponytail-activate.js\" || exit 0",
            "timeout": 5,
            "statusMessage": "Loading ponytail mode..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ln -sfn \"$CLAUDE_PROJECT_DIR/.claude/understand-anything\" \"$HOME/.understand-anything-plugin\" 2>/dev/null || true",
            "timeout": 5,
            "statusMessage": "Linking understand-anything plugin root..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/last30days/hooks/scripts/check-config.sh\" 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Checking last30days config..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v node >/dev/null 2>&1 && node \"$CLAUDE_PROJECT_DIR/.claude/ponytail/hooks/ponytail-mode-tracker.js\" || exit 0",
            "timeout": 5,
            "statusMessage": "Tracking ponytail mode..."
          }
        ]
      }
    ]
  }
}
